// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  superadmin
  author
}

enum TransferType {
  send
  return
}

enum PaymentStatus {
  created
  solicited
  paid
}

enum CategoryType {
  comissions
  regalias
}

model User {
  id                  Int       @id @default(autoincrement())
  first_name          String
  last_name           String
  referido            String?
  email               String?   @unique
  phone               String?
  birthday            String?
  clabe               String?   @unique
  name_bank_account   String?
  bank                String?
  swift               String?
  password            String?
  books               Book[]
  role                Role      @default(author)
  reset_password_code Int?
  font_size           Float?    @default(1.0)
  isDeleted           Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  payments            Payment[]
  Category            Category? @relation(fields: [categoryId], references: [id])
  categoryId          Int?

  @@unique([first_name, last_name])
}

model Book {
  id          Int          @id @default(autoincrement())
  title       String       @unique
  pasta       String?
  isbn        String?      @unique
  users       User[]
  category    Category?    @relation(fields: [categoryId], references: [id])
  categoryId  Int?         @default(1)
  inventories Inventory[]
  isDeleted   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  impressions Impression[]
  kindleSales KindleSale[]
  Cost        Cost[]
}

model Category {
  id                           Int          @id @default(autoincrement())
  number                       Int          @unique
  category_type                CategoryType @default(comissions)
  percentage_royalties         Float?
  rebate_author                Float?
  percentage_management_stores Float?
  management_min               Float?
  books                        Book[]
  isDeleted                    Boolean      @default(false)
  createdAt                    DateTime     @default(now())
  updatedAt                    DateTime     @updatedAt
  User                         User[]
}

model Bookstore {
  id              Int         @id @default(autoincrement())
  name            String      @unique
  deal_percentage Float?
  contact_name    String?
  contact_phone   String?
  contact_email   String?
  inventories     Inventory[]
  color           String?     @default("#E2E2E2")
  isDeleted       Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Inventory {
  id            Int        @id @default(autoincrement())
  book          Book       @relation(fields: [bookId], references: [id])
  bookId        Int
  bookstore     Bookstore  @relation(fields: [bookstoreId], references: [id])
  bookstoreId   Int
  country       String?
  price         Float?     @default(499.99)
  initial       Int
  current       Int
  returns       Int        @default(0)
  givenToAuthor Int        @default(0)
  sales         Sale[]
  isDeleted     Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  transfersFrom Transfer[] @relation("TransfersFrom")
  transfersTo   Transfer[] @relation("TransfersTo")

  @@unique([bookId, bookstoreId])
}

model Sale {
  id          Int       @id @default(autoincrement())
  inventory   Inventory @relation(fields: [inventoryId], references: [id])
  inventoryId Int
  payments    Payment[]
  quantity    Int       @default(1)
  isDeleted   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  date        DateTime  @default(now())
}

model KindleSale {
  id            Int       @id @default(autoincrement())
  book          Book      @relation(fields: [bookId], references: [id])
  bookId        Int
  payments      Payment[]
  quantityEbook Int?
  quantityPod   Int?
  dateCut       DateTime
  datePay       DateTime
  regalias      Float
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Impression {
  id        Int      @id @default(autoincrement())
  book      Book     @relation(fields: [bookId], references: [id])
  bookId    Int
  quantity  Int
  note      String?
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  date      DateTime @default(now())
}

model Transfer {
  id              Int          @id @default(autoincrement())
  fromInventory   Inventory    @relation("TransfersFrom", fields: [fromInventoryId], references: [id])
  fromInventoryId Int
  toInventory     Inventory?   @relation("TransfersTo", fields: [toInventoryId], references: [id])
  toInventoryId   Int?
  quantity        Int
  type            TransferType @default(send)
  note            String?
  deliveryDate    DateTime?
  place           String?
  person          String?
  isDeleted       Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Payment {
  id               Int           @id @default(autoincrement())
  user             User          @relation(fields: [userId], references: [id])
  userId           Int
  costs            Cost[]
  sales            Sale[]
  kindleSales      KindleSale[]
  forMonth         String
  dateMarkedAsPaid DateTime?
  status           PaymentStatus @default(created)
  isDeleted        Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([userId, forMonth])
}

model Cost {
  id        Int      @id @default(autoincrement())
  payment   Payment  @relation(fields: [paymentId], references: [id])
  paymentId Int
  book      Book     @relation(fields: [bookId], references: [id])
  bookId    Int
  note      String?
  amount    Float
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
